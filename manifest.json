{
    "manifest_version": 2,
    "name": "SecondGlance",
    "description": "A unified content filter.",
    "version": "1.0",

    "browser_specific_settings":
    {
        "gecko": {
            "id": "@second-glance-unif"
        }
    },

    "icons" : {
        "48" : "icons/second_glance_logo_2.png"
    },

    "content_scripts" : [
        {
            "matches" : ["*://*/*"],
            "run_at": "document_start",
            "js" : ["settings/settings.js",
                    "scripts/textScanningModel.js",
                    "scripts/module.js",
                    "scripts/adBlocker.js",
                    "scripts/featureRemover.js",
                    "scripts/textScanner.js",
                    "scripts/moduleFactory.js",
                    "scripts/main.js"]
        }
    ]
}
